
# Local .terraform directories
**/.terraform/*

# Terraform state files (we use remote S3 backend, but just in case)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lambda build artifacts
**/.build/*

# CLI configuration files
.terraformrc
terraform.rc
